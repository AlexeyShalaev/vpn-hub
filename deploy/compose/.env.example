# VPN Hub — конфигурация деплоя со встроенным PostgreSQL.
# Скопируйте и заполните:  cp .env.example .env
# Генерация секретов:      openssl rand -hex 32
#
# ЭТОТ ФАЙЛ (.env) СОДЕРЖИТ СЕКРЕТЫ — не коммитьте его, держите права 600.

# ─── Обязательное ────────────────────────────────────────────────────────────

# Мастер-ключ восстановления. Из него выводятся ключи шифрования SSH-доступов и бэкапов.
# ⚠ ПОТЕРЯ КЛЮЧА = невозможность расшифровать доступы к серверам и восстановить бэкапы.
# ⚠ На https приложение НЕ СТАРТУЕТ с пустым/дефолтным ключом. Сгенерируйте:
#     openssl rand -hex 32
VPNHUB_MASTER_KEY=

# Пароль встроенного PostgreSQL. Тоже hex (URL-safe, попадает в DATABASE_URL):
#     openssl rand -hex 32
POSTGRES_PASSWORD=

# ─── Публичный адрес ─────────────────────────────────────────────────────────

# Как панель видна снаружи. На проде — https://ваш.домен (нужен reverse-proxy с TLS,
# см. caddy.compose.yaml). На https включается HSTS и требуется валидный мастер-ключ.
VPNHUB_BASE_URL=http://localhost:8000

# Куда публиковать порт на хосте. По умолчанию — только localhost (безопасно; наружу
# выводите через reverse-proxy). Для доступа по IP без прокси (тест/LAN): 0.0.0.0:8000
VPNHUB_HTTP_ADDR=127.0.0.1:8000

# Тег образа: latest или конкретная версия (1.2.3 / 1.2). На проде рекомендуется пин.
VPNHUB_TAG=latest

# ─── HTTPS через Caddy-оверлей (рекомендуемый способ включения) ──────────────
# Закрепляет оверлей за стеком: docker compose (и update.sh) всегда видят оба файла,
# двойной -f не нужен, обновления не «разбирают» Caddy. Домен подставится в Caddyfile.
#COMPOSE_FILE=compose.yaml:caddy.compose.yaml
#VPNHUB_DOMAIN=vpn.example.com

# ─── Необязательное: первичный администратор ─────────────────────────────────
# Если заданы ОБА — админ создаётся при старте. Иначе при первом входе будет
# setup-экран (создание админа + мастер-ключа вручную).
#VPNHUB_ADMIN_PHONE=+70000000000
#VPNHUB_ADMIN_PASSWORD=

# ─── Необязательное: параметры встроенной БД ─────────────────────────────────
#POSTGRES_USER=vpnhub
#POSTGRES_DB=vpnhub

# ─── Необязательное: защита /metrics ─────────────────────────────────────────
# Если задан — /metrics требует Bearer-токен (или ?token=). Пусто → эндпоинт открыт
# (закрывайте на reverse-proxy). Prometheus: scrape с Authorization: Bearer <токен>.
#VPNHUB_METRICS_TOKEN=

# ─── Необязательное: за обратным прокси ──────────────────────────────────────
# 1 → доверять X-Forwarded-Proto (флаг Secure у cookie на https) и X-Forwarded-For
# (реальный IP клиента для rate-limit/аудита). Оставьте пустым при прямом доступе:
# иначе rate-limit обходится подделкой X-Forwarded-For. Оверлей Caddy включает это сам.
#VPNHUB_TRUSTED_PROXY=1

# ─── Необязательное: самообновление из панели (оверлей selfupdate.compose.yaml) ─
# Включает кнопку «Обновить сейчас» в разделе «Система»: Watchtower по запросу тянет
# новый образ и пересоздаёт контейнер приложения. Требует docker.sock (root на хосте).
#   COMPOSE_FILE=compose.yaml:selfupdate.compose.yaml
#   VPNHUB_UPDATE_TOKEN=<openssl rand -hex 32>
#VPNHUB_UPDATE_TOKEN=
