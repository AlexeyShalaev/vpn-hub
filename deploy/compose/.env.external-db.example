# VPN Hub — конфигурация с ВНЕШНЕЙ базой (compose.external-db.yaml).
# Скопируйте и заполните:  cp .env.external-db.example .env
#
# ЭТОТ ФАЙЛ (.env) СОДЕРЖИТ СЕКРЕТЫ — не коммитьте его, держите права 600.

# ─── Обязательное ────────────────────────────────────────────────────────────

# DSN внешнего Postgres. Драйвер asyncpg обязателен.
#   Формат:   postgresql+asyncpg://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:5432/БАЗА
#   Managed:  большинство требует TLS — добавьте ?ssl=require (или ssl=verify-full с CA).
#   Спецсимволы в пароле URL-кодируйте (@ → %40, : → %3A, / → %2F).
DATABASE_URL=postgresql+asyncpg://vpnhub:PASSWORD@db.example.com:5432/vpnhub?ssl=require

# Мастер-ключ восстановления (см. пояснение в .env.example). Сгенерируйте:
#     openssl rand -hex 32
VPNHUB_MASTER_KEY=

# ─── Публичный адрес ─────────────────────────────────────────────────────────
VPNHUB_BASE_URL=http://localhost:8000
VPNHUB_HTTP_ADDR=127.0.0.1:8000
VPNHUB_TAG=latest

# ─── HTTPS через Caddy-оверлей (рекомендуемый способ включения) ──────────────
#COMPOSE_FILE=compose.external-db.yaml:caddy.compose.yaml
#VPNHUB_DOMAIN=vpn.example.com

# ─── Необязательное: первичный администратор ─────────────────────────────────
#VPNHUB_ADMIN_PHONE=+70000000000
#VPNHUB_ADMIN_PASSWORD=

# ─── Необязательное ──────────────────────────────────────────────────────────
#VPNHUB_METRICS_TOKEN=        # если задан — /metrics требует Bearer-токен
#VPNHUB_TRUSTED_PROXY=1       # 1 за обратным прокси (X-Forwarded-Proto/For); оверлей Caddy — сам
