# Домен подставляется из переменной VPNHUB_DOMAIN (задаётся в .env; install.sh --domain … делает
# это сам). Caddy получит и будет обновлять TLS-сертификат Let's Encrypt автоматически.
# Приложение доступно по имени сервиса `app` на порту 8000. Редактировать файл не нужно.
{$VPNHUB_DOMAIN} {
	reverse_proxy app:8000
}
